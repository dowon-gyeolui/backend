# --- Secrets (NEVER commit) ---
.env
.env.*
**/.env
**/.env.*
# Except the example templates — those are safe to share.
!.env.example
!**/.env.example

# --- Python runtime ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# --- Virtual envs ---
.venv/
venv/
env/
ENV/

# --- Local databases ---
*.db
*.sqlite
*.sqlite3

# --- Packaging / build ---
*.egg-info/
*.egg
dist/
build/
.eggs/
pip-wheel-metadata/

# --- Tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# --- IDE / editor ---
.idea/
.vscode/
*.swp

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Project data (regeneratable / large / potentially copyrighted) ---
# Raw classical text sources — keep local. Commit the preprocessing scripts,
# not the content, until licensing is confirmed.
backend/data/raw/
# Processed JSONL outputs — re-derivable from raw via the scripts.
backend/data/processed/
