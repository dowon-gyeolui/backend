DATABASE_URL=postgresql+asyncpg://postgres:password@localhost/jamidusu

KAKAO_CLIENT_ID=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=http://localhost:8000/auth/kakao/callback

SECRET_KEY=change-this-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated. First entry = OAuth redirect target. All entries are CORS-allowed.
# Production example: FRONTEND_URLS=https://zami.vercel.app,http://localhost:3000
FRONTEND_URLS=http://localhost:3000

DEBUG=true

# Required for embedding (ingestion + retrieval) and translation scripts.
OPENAI_API_KEY=sk-your-openai-api-key

# Optional. LLM 응답(사주 풀이 등) 서버 캐시. 비워두면 캐시 없이 동작.
# 예: redis://localhost:6379/0 또는 rediss://default:password@host:6379
REDIS_URL=